# Server Configuration
PORT=3000

# Database Configuration (mysql or postgres)
DB_TYPE=postgres
DATABASE_URL=postgresql://your_db_user:your_db_password@your_db_host:5432/your_db_name

# Connection Details (if not using DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_local_db_password
DB_NAME=wellshine_db

# Admin Dashboard credentials
ADMIN_PASSWORD=wellshine_admin
